local function getCorners(part)
	local s  = part.Size / 2
	local cf = part.CFrame
	return {
		(cf * CFrame.new( s.X,  s.Y,  s.Z)).Position,
		(cf * CFrame.new(-s.X,  s.Y,  s.Z)).Position,
		(cf * CFrame.new( s.X, -s.Y,  s.Z)).Position,
		(cf * CFrame.new(-s.X, -s.Y,  s.Z)).Position,
		(cf * CFrame.new( s.X,  s.Y, -s.Z)).Position,
		(cf * CFrame.new(-s.X,  s.Y, -s.Z)).Position,
		(cf * CFrame.new( s.X, -s.Y, -s.Z)).Position,
		(cf * CFrame.new(-s.X, -s.Y, -s.Z)).Position,
	}
end

local function lerpColor(c1, c2, t)
	return Color3.new(
		c1.R + (c2.R - c1.R) * t,
		c1.G + (c2.G - c1.G) * t,
		c1.B + (c2.B - c1.B) * t
	)
end

