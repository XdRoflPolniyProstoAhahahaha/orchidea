	if not h then return end
	local args = {
		{
			shellMaxDist = 7000,
			origin = vector.create(-9417.2861328125, 861.3909912109375, 263.5537414550781),
			weaponName = "Knife",
			bulletID = bullet,
			currentPenetrationCount = 0,
			shellSpeed = 1000,
			maxPenetrationCount = 3,
			registeredParts = {
				[h] = true
			},
			shellType = "Bullet",
			penetrationMultiplier = 0.8,
			filterDescendants = {
				game:GetService("Players").LocalPlayer.Character,
				Instance.new("Model", nil)
			}
		},
		game:GetService("Players"):FindFirstChild(name).Character:FindFirstChild("Humanoid"),
		7645.01220703125,
		1,
		game:GetService("Players"):FindFirstChild(name).Character:FindFirstChild("Head"),
		1
	}
	game:GetService("ReplicatedStorage"):FindFirstChild("ACS_Engine"):FindFirstChild("Events"):FindFirstChild("Damage"):InvokeServer(unpack(args))
end

function findplr(ind) return game.Players:GetChildren()[ind] end

local oldd
oldd = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
	local method = getnamecallmethod()
	if typeof(self) == 'Instance' and (method == 'FireServer' or method == 'InvokeServer') then
		if self.Name == "HeadRot" then return end
		if self.Name == "ServerBullet" then
			local args = {...}

			local bulletID = nil
			for i, v in ipairs(args) do
				if type(v) == 'table' and v.bulletID then
					bulletID = v.bulletID
					break
				end
			end

			if bulletID then
				task.spawn(function()
					task.wait(0.0777)

					if ragebot_cfg.silent_kill_all then
						for i,v in ipairs(game.Players:GetChildren()) do
							if v ~= lp then
								hitplr(bulletID, v.Name)
							end
						end
					end

					if ragebot_cfg.silent_dest_vehicls then
						techies(bulletID)
					end

					warn('suck it')
				end)
			end

			return oldd(self, unpack(args))
		end
	end
	return oldd(self, ...)
end))

--norecoill (der'mo)
local currentX = 0
local currentY = 0

UserInputService.InputChanged:Connect(function(input)
    if not ragebot_cfg.NoRecoil then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        currentX = currentX - input.Delta.Y * ragebot_cfg.Sensa
        currentY = currentY - input.Delta.X * ragebot_cfg.Sensa
        currentX = math.clamp(currentX, -math.rad(90), math.rad(90))
    end
end)

RunService.RenderStepped:Connect(function()
    if ragebot_cfg.NoRecoil then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position) * CFrame.fromOrientation(currentX, currentY, 0)
    else
        local rx, ry, rz = Camera.CFrame:ToOrientation()
        currentX = rx
        currentY = ry
    end
end)

